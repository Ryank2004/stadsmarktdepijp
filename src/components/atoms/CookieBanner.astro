<div id="cookie-banner" class="cookie-banner" aria-live="polite" aria-label="Cookie toestemming">
    <div class="cookie-content">
        <p>
            Wij gebruiken <a href="/privacy" class="cookie-link">Google Ads</a> om advertenties en conversies bij te houden.
        </p>
        <div class="cookie-actions">
            <button id="cookie-reject" class="cookie-btn cookie-btn--secondary">Weigeren</button>
            <button id="cookie-accept" class="cookie-btn cookie-btn--primary">Accepteren</button>
        </div>
    </div>
</div>

<style>
    /* Mobiel: vast blokje gecentreerd onderaan */
    .cookie-banner {
        position: fixed;
        bottom: 1.25rem;
        left: 50%;
        transform: translateX(-50%) translateY(calc(100% + 2rem));
        width: 300px;
        padding: 24px;
        background-color: var(--color-dark);
        border-radius: var(--border-radius-md);
        z-index: 8999;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        transition: transform 0.4s cubic-bezier(0.33, 1.7, 0.55, 1);
    }

    @media screen and (min-width: 340px) {
        .cookie-banner {
            width: 320px;
        }
    }

    .cookie-banner.visible {
        transform: translateX(-50%) translateY(0);
    }

    .cookie-content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .cookie-content p {
        color: var(--color-light);
        font-family: var(--font-body);
        font-size: 13px;
        line-height: 1.5;
        text-align: center;
    }

    .cookie-link {
        color: var(--color-light);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .cookie-actions {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
    }

    .cookie-btn {
        font-family: var(--font-body);
        font-size: 12px;
        font-weight: 700;
        padding: 0.4rem 0.9rem;
        border-radius: 999px;
        border: 1.5px solid var(--color-light);
        cursor: pointer;
        transition: opacity 0.2s ease;
        white-space: nowrap;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .cookie-btn:hover {
        opacity: 0.75;
    }

    .cookie-btn--secondary {
        background: transparent;
        color: var(--color-light);
    }

    .cookie-btn--primary {
        background: var(--color-primary);
        color: var(--color-light);
        border-color: var(--color-primary);
    }

    /* Desktop: langere variant rechtsonder */
    @media screen and (min-width: 600px) {
        .cookie-banner {
            left: auto;
            right: 1.5rem;
            bottom: 1.5rem;
            width: 560px;
            transform: translateY(calc(100% + 2rem));
            padding-bottom: max(24px, env(safe-area-inset-bottom));
        }

        .cookie-banner.visible {
            transform: translateY(0);
        }

        .cookie-content {
            flex-direction: row;
            align-items: center;
            gap: 1.25rem;
        }

        .cookie-content p {
            text-align: left;
            /* white-space: nowrap; */
        }

        .cookie-actions {
            flex-shrink: 0;
        }
    }
</style>

<script>
    const CONSENT_KEY = "cookie-consent";
    const banner = document.getElementById("cookie-banner");
    const acceptBtn = document.getElementById("cookie-accept");
    const rejectBtn = document.getElementById("cookie-reject");

    function loadGtag() {
        const script = document.createElement("script");
        script.async = true;
        script.src = "https://www.googletagmanager.com/gtag/js?id=AW-18109424275";
        document.head.appendChild(script);

        script.onload = () => {
            (window as any).dataLayer = (window as any).dataLayer || [];
            function gtag(...args: any[]) { (window as any).dataLayer.push(args); }
            (window as any).gtag = gtag;
            gtag("js", new Date());
            gtag("config", "AW-18109424275");
        };
    }

    function hideBanner() {
        banner?.classList.remove("visible");
    }

    const consent = localStorage.getItem(CONSENT_KEY);

    if (consent === "accepted") {
        loadGtag();
    } else if (consent === null) {
        setTimeout(() => banner?.classList.add("visible"), 800);
    }

    acceptBtn?.addEventListener("click", () => {
        localStorage.setItem(CONSENT_KEY, "accepted");
        loadGtag();
        hideBanner();
    });

    rejectBtn?.addEventListener("click", () => {
        localStorage.setItem(CONSENT_KEY, "rejected");
        hideBanner();
    });
</script>
